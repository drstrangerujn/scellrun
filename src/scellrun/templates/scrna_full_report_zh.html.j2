<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<title>scellrun — 完整流程报告</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Segoe UI", sans-serif; max-width: 1080px; margin: 2rem auto; padding: 0 1rem; color: #222; line-height: 1.7; }
  h1 { font-size: 1.7rem; border-bottom: 2px solid #333; padding-bottom: .3rem; }
  h2 { font-size: 1.15rem; margin-top: 2.2rem; padding-bottom: .15rem; border-bottom: 1px solid #eee; }
  a { color: #1f4e8a; }
  .stage-card { padding: .8rem 1rem; border: 1px solid #e6e6e6; border-radius: .4rem; margin: .8rem 0; background: #fafafa; }
  .stage-card.absent { opacity: .55; background: #f3f3f3; }
  .pill { display: inline-block; padding: .1rem .55rem; border-radius: .8rem; background: #eef4ff; color: #1f4e8a; font-size: .82rem; font-weight: 600; }
  .pill.absent { background: #eee; color: #888; }
  table.runs { font-size: .88rem; width: 100%; border-collapse: collapse; }
  table.runs th, table.runs td { border: 1px solid #ddd; padding: .3rem .5rem; text-align: left; }
  table.runs th { background: #f6f6f6; }
  code { background: #f0f0f0; padding: .05rem .3rem; border-radius: 3px; font-size: .9em; }
  ul.artifacts { list-style: square; padding-left: 1.2rem; font-size: .9rem; }
  .provenance { background: #fafaf6; border-left: 3px solid #c7b07a; padding: .6rem .9rem; margin: .8rem 0 1.2rem; font-size: .92rem; color: #555; }
  table.decisions { font-size: .88rem; width: 100%; border-collapse: collapse; margin-top: .4rem; }
  table.decisions th, table.decisions td { border: 1px solid #e3e3e3; padding: .3rem .55rem; text-align: left; vertical-align: top; }
  table.decisions th { background: #f6f6f6; font-weight: 600; }
  table.decisions tr.user td { background: #fff8ef; }
  .badge { display: inline-block; padding: .05rem .45rem; border-radius: .7rem; font-size: .72rem; font-weight: 600; letter-spacing: .02em; }
  .badge-auto { background: #eef4ff; color: #1f4e8a; }
  .badge-user { background: #fdf0d8; color: #8a5a1f; }
  .badge-ai   { background: #efe4ff; color: #5a1f8a; }
  .stage-head { font-size: 1rem; margin: 1.2rem 0 .3rem; color: #333; font-weight: 600; }
  .summary-counts { color: #666; font-size: .9rem; margin-top: .2rem; }
  .glance { background: #f8fbff; border-left: 3px solid #1f4e8a; padding: .8rem 1rem; margin: .6rem 0 1rem; }
  .glance-row { margin: .25rem 0; font-size: .95rem; }
  .glance-label { color: #555; min-width: 11rem; display: inline-block; }
  .glance-trigger { color: #b34141; font-weight: 600; }
  .glance ul { margin: .25rem 0 .25rem 1.2rem; padding: 0; }
</style>
</head>
<body>

<h1>scellrun — 完整流程报告</h1>

<p style="color:#666;">运行目录：<code>{{ run_dir }}</code></p>

<h2>一览</h2>
<div class="glance">
  <div class="glance-row">
    <span class="glance-label">QC 通过率：</span>
    {% if glance.qc_pass_rate_pct is not none %}
      <strong>{{ "%.1f"|format(glance.qc_pass_rate_pct) }}%</strong>
      {% if glance.qc_n_pass is not none and glance.qc_n_in is not none %}
        （{{ glance.qc_n_pass }} / {{ glance.qc_n_in }} 个细胞）
      {% endif %}
    {% else %}
      <em>暂无</em>
    {% endif %}
  </div>
  <div class="glance-row">
    <span class="glance-label">整合方法：</span>
    {% if glance.method %}<code>{{ glance.method }}</code>{% else %}<em>—</em>{% endif %}
  </div>
  <div class="glance-row">
    <span class="glance-label">注释 panel：</span>
    {% if glance.panel %}<code>{{ glance.panel }}</code>{% else %}<em>—</em>{% endif %}
  </div>
  <div class="glance-row">
    <span class="glance-label">所选分辨率：</span>
    {% if glance.chosen_resolution is not none %}
      <code>{{ glance.chosen_resolution }}</code>
      {% if glance.n_clusters is not none %}
        — 共 <strong>{{ glance.n_clusters }}</strong> 个 cluster
      {% endif %}
    {% else %}
      <em>—</em>
    {% endif %}
  </div>
  {% if glance.top_celltypes %}
  <div class="glance-row">
    <span class="glance-label">主要细胞类型：</span>
    <ul>
      {% for ct in glance.top_celltypes %}
        <li><code>{{ ct.label }}</code>——{{ ct.n_clusters }} 个 cluster</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
  {% if glance.self_check_codes %}
  <div class="glance-row">
    <span class="glance-label">自检告警：</span>
    {% for code in glance.self_check_codes %}
      <span class="glance-trigger">{{ code }}</span>{% if not loop.last %}，{% endif %}
    {% endfor %}
  </div>
  {% endif %}
</div>

<h2>决策摘要</h2>
{% if decisions_by_stage %}
<p class="summary-counts">
  共记录 {{ n_decisions_total }} 条决策，覆盖 {{ decisions_by_stage|length }} 个阶段{% if n_ai_decisions %}，其中 {{ n_ai_decisions }} 条来自 AI{% endif %}。
  橙色行是用户手动覆盖；<span class="badge badge-ai">ai</span> 标签表示 AI 给出的判断。
</p>
{% for stage, items in decisions_by_stage %}
  <div class="stage-head">{{ stage }}</div>
  <table class="decisions">
    <thead>
      <tr><th>来源</th><th>键</th><th>取值</th><th>默认</th><th>理由</th></tr>
    </thead>
    <tbody>
      {% for d in items %}
      <tr class="{{ d.source }}">
        <td><span class="badge badge-{{ d.source }}">{{ d.source }}</span></td>
        <td><code>{{ d.key }}</code></td>
        <td>{% if d.value is none %}<em>无</em>{% else %}<code>{{ d.value }}</code>{% endif %}</td>
        <td>
          {% if d.default is none or d.default == d.value %}
            <span style="color:#aaa;">—</span>
          {% else %}
            <code style="color:#999;">{{ d.default }}</code>
          {% endif %}
        </td>
        <td style="color:#555;">{{ d.rationale }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
{% endfor %}
{% else %}
<p style="color:#999;">没找到决策日志——这个 run 是 scellrun &lt; 0.7.0 产生的吗？</p>
{% endif %}

<h2>分析阶段</h2>
{% for stage in stages %}
<div class="stage-card {% if not stage.present %}absent{% endif %}">
  <div>
    <span class="pill {% if not stage.present %}absent{% endif %}">{{ loop.index0 + 1 }}. {{ stage.name }}</span>
    {% if stage.present %}
      <span style="font-size:.85rem; color:#555;">→ <code>{{ stage.dir_name }}/</code></span>
      {% if stage.report_path %}
        — <a href="../{{ stage.dir_name }}/report.html">打开 report.html</a>
      {% endif %}
    {% else %}
      <span style="font-size:.85rem; color:#999;">（未运行）</span>
    {% endif %}
  </div>
  {% if stage.present and stage.artifacts %}
  <ul class="artifacts">
    {% for name, path in stage.artifacts.items() %}
      <li><a href="../{{ stage.dir_name }}/{{ name }}">{{ name }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}
</div>
{% endfor %}

<h2>运行清单（按时间顺序）</h2>
{% if manifest.stages %}
<table class="runs">
  <thead>
    <tr><th>#</th><th>命令</th><th>运行时间</th><th>关键参数</th></tr>
  </thead>
  <tbody>
    {% for s in manifest.stages %}
    <tr>
      <td>{{ loop.index }}</td>
      <td><code>{{ s.command }}</code></td>
      <td>{{ s.ran_at }}</td>
      <td style="font-size:.78rem; color:#555;">
        {% for k, v in s.params.items() %}
          {% if k != "h5ad" and k != "out_dir" %}
            <span style="margin-right:.6rem;">{{ k }}=<code>{{ v }}</code></span>
          {% endif %}
        {% endfor %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p style="color:#999;">没找到运行清单——这个 run-dir 是 scellrun ≥ 0.1.2 产生的吗？</p>
{% endif %}

<h2>证据链</h2>
<div class="provenance">
  每个 stage 的报告都带三层证据：
  <ul style="margin: .4rem 0 0 1rem;">
    <li><strong>数据</strong>——per-cell 指标、cluster 大小、样本混合。</li>
    <li><strong>推断</strong>——带 rationale 的 opinionated 阈值；panel 匹配（带分数和与第二名的差距）。</li>
    <li><strong>文献</strong>——annotate 阶段开了 <code>--pubmed</code> 的话，每个 marker 配近期 PubMed 论文。</li>
  </ul>
</div>

<p style="font-size:.85rem; color:#888; margin-top:2rem;">
  由 <code>scellrun report</code> 生成。要导成 PDF，浏览器打开这个页面用"打印 → 保存为 PDF"即可（Chromium 打印这种布局干净）。
</p>

</body>
</html>

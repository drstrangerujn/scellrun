<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>scellrun — full pipeline report</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; max-width: 1080px; margin: 2rem auto; padding: 0 1rem; color: #222; line-height: 1.55; }
  h1 { font-size: 1.7rem; border-bottom: 2px solid #333; padding-bottom: .3rem; }
  h2 { font-size: 1.15rem; margin-top: 2.2rem; padding-bottom: .15rem; border-bottom: 1px solid #eee; }
  h3 { font-size: 1rem; color: #555; margin-top: 1.4rem; }
  a { color: #1f4e8a; }
  .stage-card { padding: .8rem 1rem; border: 1px solid #e6e6e6; border-radius: .4rem; margin: .8rem 0; background: #fafafa; }
  .stage-card.absent { opacity: .55; background: #f3f3f3; }
  .pill { display: inline-block; padding: .1rem .55rem; border-radius: .8rem; background: #eef4ff; color: #1f4e8a; font-size: .8rem; font-weight: 600; }
  .pill.absent { background: #eee; color: #888; }
  table.runs { font-size: .88rem; width: 100%; border-collapse: collapse; }
  table.runs th, table.runs td { border: 1px solid #ddd; padding: .3rem .5rem; text-align: left; }
  table.runs th { background: #f6f6f6; }
  code { background: #f0f0f0; padding: .05rem .3rem; border-radius: 3px; font-size: .9em; }
  ul.artifacts { list-style: square; padding-left: 1.2rem; font-size: .9rem; }
  .provenance { background: #fafaf6; border-left: 3px solid #c7b07a; padding: .6rem .9rem; margin: .8rem 0 1.2rem; font-size: .92rem; color: #555; }
  table.decisions { font-size: .88rem; width: 100%; border-collapse: collapse; margin-top: .4rem; }
  table.decisions th, table.decisions td { border: 1px solid #e3e3e3; padding: .3rem .55rem; text-align: left; vertical-align: top; }
  table.decisions th { background: #f6f6f6; font-weight: 600; }
  table.decisions tr.user td { background: #fff8ef; }
  .badge { display: inline-block; padding: .05rem .45rem; border-radius: .7rem; font-size: .72rem; font-weight: 600; letter-spacing: .02em; }
  .badge-auto { background: #eef4ff; color: #1f4e8a; }
  .badge-user { background: #fdf0d8; color: #8a5a1f; }
  .badge-ai   { background: #efe4ff; color: #5a1f8a; }
  .stage-head { font-size: 1rem; margin: 1.2rem 0 .3rem; color: #333; font-weight: 600; }
  .summary-counts { color: #666; font-size: .9rem; margin-top: .2rem; }
  .glance { background: #f8fbff; border-left: 3px solid #1f4e8a; padding: .8rem 1rem; margin: .6rem 0 1rem; }
  .glance-row { margin: .25rem 0; font-size: .95rem; }
  .glance-label { color: #555; min-width: 11rem; display: inline-block; }
  .glance-trigger { color: #b34141; font-weight: 600; }
  .glance-trigger-text { color: #555; font-size: .9rem; margin-left: .25rem; }
  .glance-rationale { color: #555; font-size: .85rem; margin-left: 11rem; margin-top: .15rem; line-height: 1.4; }
  .glance-self-check-list { margin: .3rem 0 .3rem 11rem; }
  .glance ul { margin: .25rem 0 .25rem 1.2rem; padding: 0; }
</style>
</head>
<body>

<h1>scellrun — full pipeline report</h1>

<p style="color:#666;">
  Run directory: <code>{{ run_dir }}</code>
</p>

<p style="font-size:.92rem;">
  <strong>Views:</strong>
  <a href="../06_views/index.html">by resolution / by cluster / by decision source</a>
</p>

<h2>At a glance</h2>
<div class="glance">
  <div class="glance-row">
    <span class="glance-label">QC pass rate:</span>
    {% if glance.qc_pass_rate_pct is not none %}
      <strong>{{ "%.1f"|format(glance.qc_pass_rate_pct) }}%</strong>
      {% if glance.qc_n_pass is not none and glance.qc_n_in is not none %}
        ({{ glance.qc_n_pass }} / {{ glance.qc_n_in }} cells)
      {% endif %}
    {% else %}
      <em>not available</em>
    {% endif %}
  </div>
  <div class="glance-row">
    <span class="glance-label">Integration method:</span>
    {% if glance.method %}<code>{{ glance.method }}</code>{% else %}<em>—</em>{% endif %}
  </div>
  <div class="glance-row">
    <span class="glance-label">Annotation panel:</span>
    {% if glance.panel %}<code>{{ glance.panel }}</code>{% else %}<em>—</em>{% endif %}
    {% if glance.panel_rationale %}
      <div class="glance-rationale">{{ glance.panel_rationale }}</div>
    {% endif %}
  </div>
  <div class="glance-row">
    <span class="glance-label">Chosen resolution:</span>
    {% if glance.chosen_resolution is not none %}
      <code>{{ glance.chosen_resolution }}</code>
      {% if glance.chosen_resolution_source == "ai" %}
        <span class="badge badge-ai">ai</span>
      {% endif %}
      {% if glance.n_clusters is not none %}
        — <strong>{{ glance.n_clusters }}</strong> clusters
      {% endif %}
      {% if glance.chosen_resolution_rationale %}
        <div class="glance-rationale">{{ glance.chosen_resolution_rationale }}</div>
      {% endif %}
    {% else %}
      <em>—</em>
    {% endif %}
  </div>
  {% if glance.top_celltypes %}
  <div class="glance-row">
    <span class="glance-label">Top cell-type labels:</span>
    <ul>
      {% for ct in glance.top_celltypes %}
        <li><code>{{ ct.label }}</code> — {{ ct.n_clusters }} cluster(s)</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
  {% if glance.self_check_findings %}
  <div class="glance-row">
    <span class="glance-label">Self-check triggers:</span>
    <ul class="glance-self-check-list">
      {% for f in glance.self_check_findings %}
        <li>
          <span class="glance-trigger">{{ f.code }}</span>
          {% if f.rationale %}<span class="glance-trigger-text">— {{ f.rationale }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  {% elif glance.self_check_codes %}
  <div class="glance-row">
    <span class="glance-label">Self-check triggers:</span>
    {% for code in glance.self_check_codes %}
      <span class="glance-trigger">{{ code }}</span>{% if not loop.last %}, {% endif %}
    {% endfor %}
  </div>
  {% endif %}
</div>

<h2>Decision summary</h2>
{% if decisions_by_stage %}
<p class="summary-counts">
  {{ n_decisions_total }} decisions logged across {{ decisions_by_stage|length }} stage(s){% if n_ai_decisions %}, {{ n_ai_decisions }} from AI{% endif %}.
  Rows shaded amber were user overrides; <span class="badge badge-ai">ai</span> tags an AI-driven choice.
</p>
{% for stage, items in decisions_by_stage %}
  <div class="stage-head">{{ stage }}</div>
  <table class="decisions">
    <thead>
      <tr><th>source</th><th>key</th><th>value</th><th>default</th><th>rationale</th></tr>
    </thead>
    <tbody>
      {% for d in items %}
      <tr class="{{ d.source }}">
        <td><span class="badge badge-{{ d.source }}">{{ d.source }}</span></td>
        <td><code>{{ d.key }}</code></td>
        <td>{% if d.value is none %}<em>none</em>{% else %}<code>{{ d.value }}</code>{% endif %}</td>
        <td>
          {% if d.default is none or d.default == d.value %}
            <span style="color:#aaa;">—</span>
          {% else %}
            <code style="color:#999;">{{ d.default }}</code>
          {% endif %}
        </td>
        <td style="color:#555;">{{ d.rationale }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
{% endfor %}
{% else %}
<p style="color:#999;">No decisions log found — was this run produced by scellrun &lt; 0.7.0?</p>
{% endif %}

<h2>Stages</h2>
{% for stage in stages %}
<div class="stage-card {% if not stage.present %}absent{% endif %}">
  <div>
    <span class="pill {% if not stage.present %}absent{% endif %}">{{ loop.index0 + 1 }}. {{ stage.name }}</span>
    {% if stage.present %}
      <span style="font-size:.85rem; color:#555;">→ <code>{{ stage.dir_name }}/</code></span>
      {% if stage.report_path %}
        — <a href="../{{ stage.dir_name }}/report.html">open report.html</a>
      {% endif %}
    {% else %}
      <span style="font-size:.85rem; color:#999;">(not run)</span>
    {% endif %}
  </div>
  {% if stage.present and stage.artifacts %}
  <ul class="artifacts">
    {% for name, path in stage.artifacts.items() %}
      <li><a href="../{{ stage.dir_name }}/{{ name }}">{{ name }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}
</div>
{% endfor %}

<h2>Run manifest (chronological)</h2>
{% if manifest.stages %}
<table class="runs">
  <thead>
    <tr><th>#</th><th>command</th><th>ran at</th><th>key params</th></tr>
  </thead>
  <tbody>
    {% for s in manifest.stages %}
    <tr>
      <td>{{ loop.index }}</td>
      <td><code>{{ s.command }}</code></td>
      <td>{{ s.ran_at }}</td>
      <td style="font-size:.78rem; color:#555;">
        {% for k, v in s.params.items() %}
          {% if k != "h5ad" and k != "out_dir" %}
            <span style="margin-right:.6rem;">{{ k }}=<code>{{ v }}</code></span>
          {% endif %}
        {% endfor %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p style="color:#999;">No manifest found — was this run-dir produced by scellrun ≥ 0.1.2?</p>
{% endif %}

<h2>Provenance trail</h2>
<div class="provenance">
  Each stage's report carries three tiers of evidence:
  <ul style="margin: .4rem 0 0 1rem;">
    <li><strong>Data</strong> — per-cell metrics, cluster sizes, sample mixing.</li>
    <li><strong>Inference</strong> — opinionated thresholds (with rationale text in each report) and panel matches (with score / margin to runner-up).</li>
    <li><strong>Literature</strong> — when <code>--pubmed</code> is enabled at the annotate stage, top recent PubMed papers per marker.</li>
  </ul>
</div>

<p style="font-size:.85rem; color:#888; margin-top:2rem;">
  Generated by <code>scellrun report</code>. To export to PDF, open this page in
  a browser and use Print → Save as PDF (Chromium prints these layouts cleanly).
</p>

</body>
</html>

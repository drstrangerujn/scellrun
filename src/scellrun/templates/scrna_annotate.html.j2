<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>scellrun — scRNA cluster annotation</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; max-width: 1080px; margin: 2rem auto; padding: 0 1rem; color: #222; line-height: 1.55; }
  h1 { font-size: 1.6rem; border-bottom: 2px solid #333; padding-bottom: .3rem; }
  h2 { font-size: 1.1rem; margin-top: 2rem; }
  h3 { font-size: 1rem; margin-top: 1.4rem; color: #333; }
  table { border-collapse: collapse; width: 100%; margin: .3rem 0 1.2rem; font-size: .9rem; }
  th, td { border: 1px solid #ddd; padding: .35rem .5rem; vertical-align: top; }
  th { background: #f6f6f6; text-align: left; }
  .label-pill { display: inline-block; padding: .1rem .5rem; border-radius: .8rem; background: #eef4ff; color: #1f4e8a; font-weight: 600; font-size: .85rem; }
  .ai-pill { background: #faf3ee; color: #8a4f1f; }
  .markers { font-family: ui-monospace, "SF Mono", monospace; font-size: .82rem; color: #555; }
  .rationale-line { color: #555; font-size: .85rem; }
  .pubmed-list { margin: .25rem 0; padding-left: 1.2rem; font-size: .85rem; }
  .pubmed-list li { margin-bottom: .15rem; }
  .ambiguous { color: #b56; font-weight: 600; }
  footer { color: #888; font-size: .82rem; margin-top: 3rem; border-top: 1px solid #eee; padding-top: .7rem; }
</style>
</head>
<body>

<h1>scRNA-seq cluster annotation</h1>

<dl style="display:grid; grid-template-columns: 200px 1fr; gap:.2rem .8rem; font-size:.92rem;">
  <dt>Resolution</dt>      <dd>{{ result.resolution }}</dd>
  <dt>Panel used</dt>      <dd>{{ result.panel_name }}</dd>
  <dt>Tissue context</dt>  <dd>{{ result.tissue or "(not provided — pass --tissue for better PubMed evidence)" }}</dd>
  <dt>AI second opinion</dt><dd>{{ "yes" if result.used_ai else "no (--ai disabled)" }}</dd>
  <dt>PubMed evidence</dt> <dd>{{ "yes" if result.used_pubmed else "no (--pubmed disabled)" }}</dd>
  <dt>Total clusters</dt>  <dd>{{ result.annotations | length }}</dd>
</dl>

<h2>Per-cluster annotations</h2>
<p style="color:#666; font-size:.9rem;">
  <strong>panel_label</strong> = highest-scoring group in the profile panel; <strong>margin</strong>
  is the gap to the runner-up (small margin = ambiguous, eyeball it).
  When <code>--ai</code> is on, the LLM's independent judgment is shown side-by-side; the user picks.
</p>

<table>
  <thead>
    <tr>
      <th>Cluster</th>
      <th>Panel label (score / margin)</th>
      {% if result.used_ai %}<th>AI label</th>{% endif %}
      <th>Top markers (10)</th>
      <th>Rationale</th>
    </tr>
  </thead>
  <tbody>
  {% for a in result.annotations %}
    <tr>
      <td><strong>{{ a.cluster }}</strong></td>
      <td>
        <span class="label-pill {% if a.panel_margin < 0.05 %}ambiguous{% endif %}">{{ a.panel_label }}</span><br>
        <span style="font-size:.8rem; color:#666;">score {{ "%.2f"|format(a.panel_score) }}, margin {{ "%.2f"|format(a.panel_margin) }}</span>
      </td>
      {% if result.used_ai %}
      <td>
        {% if a.ai_label %}
          <span class="label-pill ai-pill">{{ a.ai_label }}</span><br>
          <span class="rationale-line">{{ a.ai_rationale }}</span>
        {% else %}
          <span style="color:#999; font-size:.85rem;">—</span><br>
          <span class="rationale-line">{{ a.ai_rationale or "(skipped)" }}</span>
        {% endif %}
      </td>
      {% endif %}
      <td class="markers">{{ a.top_markers[:10] | join(", ") }}</td>
      <td class="rationale-line">{{ a.panel_rationale }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>

{% if result.used_pubmed %}
<h2>PubMed evidence (top markers per cluster)</h2>
{% for a in result.annotations %}
<h3>Cluster {{ a.cluster }} — {{ a.panel_label }}</h3>
{% if a.pubmed %}
  {% for gene, papers in a.pubmed.items() %}
    <p><strong>{{ gene }}</strong></p>
    {% if papers %}
    <ul class="pubmed-list">
      {% for p in papers %}
        <li>{{ p.year }} — <a href="{{ p.url }}" target="_blank">{{ p.title }}</a></li>
      {% endfor %}
    </ul>
    {% else %}
    <p style="color:#999; font-size:.85rem;">(no recent PubMed hits for this gene + tissue)</p>
    {% endif %}
  {% endfor %}
{% else %}
  <p style="color:#999; font-size:.9rem;">No PubMed evidence retrieved for this cluster.</p>
{% endif %}
{% endfor %}
{% endif %}

<h2>Next step</h2>
<p>
  <code>annotated.h5ad</code> ships <code>obs.scellrun_celltype_panel</code>{% if result.used_ai %} and <code>obs.scellrun_celltype_ai</code>{% endif %}
  as category columns. Decide which to take forward (or override per-cluster
  in scanpy and re-export). v0.5 <code>scellrun report</code> will tie QC + integrate +
  markers + annotate into one PDF deliverable with the three-tier provenance trail.
</p>

<footer>
  Generated by scellrun. Annotation defaults: deterministic panel match, optional LLM second opinion,
  optional PubMed evidence. The user always makes the final call.
</footer>

</body>
</html>
